model Product {
  id          String   @id @default(uuid())
  eanCode     String   @unique
  name        String
  category    String   // cosmetics, electronics vb.
  threeDModel String?
  prices      Price[]
}

model Price {
  id             String   @id @default(uuid())
  countryCode    String
  currency       String
  basePrice      Float
  shippingFee    Float
  productId      String
  product        Product  @relation(fields: [productId], references: [id])
}